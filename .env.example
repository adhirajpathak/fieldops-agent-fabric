# LLM provider: vertex | openai | mock
LLM_PROVIDER=mock

# Vertex AI (recommended for GCP FDE narrative)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_REGION=us-central1
VERTEX_MODEL=gemini-2.0-flash

# OpenAI (optional local dev)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# RAG
CHROMA_PERSIST_DIR=./data/chroma
KNOWLEDGE_BASE_DIR=./data/knowledge_base

# Observability
OTEL_SERVICE_NAME=fieldops-agent-fabric
OTEL_EXPORT_GCP=true

# API
FIELDOPS_API_HOST=0.0.0.0
FIELDOPS_API_PORT=8080
